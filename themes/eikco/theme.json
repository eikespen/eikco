{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "680px",
			"wideSize": "1160px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "base",     "color": "#ffffff", "name": "Paper" },
				{ "slug": "base-2",   "color": "#faf8f5", "name": "Warm Paper" },
				{ "slug": "ink",      "color": "#2e2c2c", "name": "Ink" },
				{ "slug": "subtle",   "color": "#6a6663", "name": "Subtle" },
				{ "slug": "hairline", "color": "#e5e1db", "name": "Hairline" },
				{ "slug": "accent",   "color": "#003d3a", "name": "Deep Teal" },
				{ "slug": "accent-2", "color": "#c88f5a", "name": "Warm Tan" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "serif",
					"name": "Libre Baskerville",
					"fontFamily": "\"Libre Baskerville\", Georgia, \"Times New Roman\", serif",
					"fontFace": [
						{
							"fontFamily": "Libre Baskerville",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": ["https://fonts.gstatic.com/s/librebaskerville/v14/kmKnZrc3Hgbbcjq75U4uslyuy4kn0pNeYRI4CN2V.woff2"]
						},
						{
							"fontFamily": "Libre Baskerville",
							"fontStyle": "italic",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": ["https://fonts.gstatic.com/s/librebaskerville/v14/kmKhZrc3Hgbbcjq75U4uslyuy4kn0qviTjY0C4G8Aw.woff2"]
						},
						{
							"fontFamily": "Libre Baskerville",
							"fontStyle": "normal",
							"fontWeight": "700",
							"fontDisplay": "swap",
							"src": ["https://fonts.gstatic.com/s/librebaskerville/v14/kmKiZrc3Hgbbcjq75U4uslyuy4kn0pNedw7Ig8HDCpM.woff2"]
						}
					]
				},
				{
					"slug": "sans",
					"name": "Nunito Sans",
					"fontFamily": "\"Nunito Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Helvetica, Arial, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Nunito Sans",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": ["https://fonts.gstatic.com/s/nunitosans/v15/pe0qMImSLYBIv1o4X1M8cce4GR1V7VkA8A.woff2"]
						},
						{
							"fontFamily": "Nunito Sans",
							"fontStyle": "normal",
							"fontWeight": "600",
							"fontDisplay": "swap",
							"src": ["https://fonts.gstatic.com/s/nunitosans/v15/pe0qMImSLYBIv1o4X1M8cce4GR1V7VkA8A.woff2"]
						}
					]
				},
				{
					"slug": "mono",
					"name": "Plex Mono",
					"fontFamily": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
					"fontFace": [
						{
							"fontFamily": "IBM Plex Mono",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": ["https://fonts.gstatic.com/s/ibmplexmono/v19/-F63fjptAgt5VM-kVkqdyU8n5igg1l9kn-s.woff2"]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "small",    "size": "0.8125rem", "name": "Small" },
				{ "slug": "medium",   "size": "1.0625rem", "name": "Medium" },
				{ "slug": "large",    "size": "1.25rem",   "name": "Large" },
				{ "slug": "x-large",  "size": "clamp(1.75rem, 2vw + 1rem, 2.5rem)", "name": "X-Large" },
				{ "slug": "xx-large", "size": "clamp(2.5rem, 5vw + 1rem, 4.5rem)",  "name": "XX-Large" }
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vw", "vh"],
			"spacingSizes": [
				{ "slug": "20", "size": "clamp(0.5rem, 0.5vw + 0.25rem, 0.75rem)",  "name": "1 — XS" },
				{ "slug": "30", "size": "clamp(0.75rem, 1vw + 0.5rem, 1.25rem)",    "name": "2 — S"  },
				{ "slug": "40", "size": "clamp(1rem, 2vw + 0.5rem, 2rem)",          "name": "3 — M"  },
				{ "slug": "50", "size": "clamp(2rem, 4vw + 1rem, 4rem)",            "name": "4 — L"  },
				{ "slug": "60", "size": "clamp(3rem, 6vw + 1rem, 6rem)",            "name": "5 — XL" },
				{ "slug": "70", "size": "clamp(5rem, 10vw + 1rem, 10rem)",          "name": "6 — XXL"}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "400",
					"lineHeight": "1.15",
					"letterSpacing": "-0.005em"
				}
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)"  } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--large)", "fontWeight": "400" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--accent)" },
				"typography": { "textDecoration": "underline", "textUnderlineOffset": "0.15em" },
				":hover": { "color": { "text": "var(--wp--preset--color--ink)" } }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--base)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--small)",
					"textDecoration": "none",
					"letterSpacing": "0.02em",
					"textTransform": "none"
				},
				"spacing": {
					"padding": {
						"top": "0.9rem", "bottom": "0.9rem",
						"left": "1.6rem", "right": "1.6rem"
					}
				},
				"border": {
					"radius": "4px",
					"width": "0",
					"style": "solid",
					"color": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--ink)",
						"text": "var(--wp--preset--color--base)"
					}
				}
			}
		},
		"blocks": {
			"core/separator": {
				"color": { "background": "var(--wp--preset--color--hairline)" }
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "400"
				}
			},
			"core/post-date": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"color": { "text": "var(--wp--preset--color--subtle)" }
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--large)",
					"letterSpacing": "0.02em"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "400",
					"letterSpacing": "0.01em"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontStyle": "italic"
				},
				"border": { "width": "0" }
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-wide", "title": "Wide page", "postTypes": ["page"] }
	]
}
