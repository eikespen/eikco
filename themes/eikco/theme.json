{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "640px",
			"wideSize": "1080px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{ "slug": "base",     "color": "#ffffff", "name": "Paper" },
				{ "slug": "ink",      "color": "#0a0a0a", "name": "Ink" },
				{ "slug": "subtle",   "color": "#5a5a5a", "name": "Subtle" },
				{ "slug": "hairline", "color": "#e8e8e8", "name": "Hairline" },
				{ "slug": "accent",   "color": "#c2410c", "name": "Rust" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "serif",
					"name": "Newsreader",
					"fontFamily": "Newsreader, Georgia, \"Times New Roman\", serif"
				},
				{
					"slug": "mono",
					"name": "Plex Mono",
					"fontFamily": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
				}
			],
			"fontSizes": [
				{ "slug": "small",    "size": "0.8125rem", "name": "Small" },
				{ "slug": "medium",   "size": "1.0625rem", "name": "Medium" },
				{ "slug": "large",    "size": "1.25rem",   "name": "Large" },
				{ "slug": "x-large",  "size": "clamp(1.75rem, 2vw + 1rem, 2.5rem)", "name": "X-Large" },
				{ "slug": "xx-large", "size": "clamp(2.5rem, 5vw + 1rem, 4.75rem)", "name": "XX-Large" }
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vw", "vh"],
			"spacingSizes": [
				{ "slug": "20", "size": "clamp(0.5rem, 0.5vw + 0.25rem, 0.75rem)",  "name": "1 — XS" },
				{ "slug": "30", "size": "clamp(0.75rem, 1vw + 0.5rem, 1.25rem)",    "name": "2 — S"  },
				{ "slug": "40", "size": "clamp(1rem, 2vw + 0.5rem, 2rem)",          "name": "3 — M"  },
				{ "slug": "50", "size": "clamp(2rem, 4vw + 1rem, 4rem)",            "name": "4 — L"  },
				{ "slug": "60", "size": "clamp(3rem, 6vw + 1rem, 6rem)",            "name": "5 — XL" },
				{ "slug": "70", "size": "clamp(5rem, 10vw + 1rem, 10rem)",          "name": "6 — XXL"}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--serif)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.65"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "500",
					"lineHeight": "1.1",
					"letterSpacing": "-0.01em"
				}
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--xx-large)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--x-large)"  } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--large)", "fontWeight": "500" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--accent)" },
				"typography": { "textDecoration": "underline" },
				":hover": { "color": { "text": "var(--wp--preset--color--ink)" } }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--base)",
					"text": "var(--wp--preset--color--accent)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontWeight": "400",
					"fontSize": "var(--wp--preset--font-size--small)",
					"textDecoration": "none",
					"letterSpacing": "0.02em"
				},
				"spacing": {
					"padding": {
						"top": "0.5rem", "bottom": "0.5rem",
						"left": "0", "right": "0"
					}
				},
				"border": {
					"radius": "0",
					"width": "0 0 1px 0",
					"style": "solid",
					"color": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--ink)"
					},
					"border": { "color": "var(--wp--preset--color--ink)" }
				}
			}
		},
		"blocks": {
			"core/separator": {
				"color": { "background": "var(--wp--preset--color--hairline)" }
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "500"
				}
			},
			"core/post-date": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"color": { "text": "var(--wp--preset--color--subtle)" }
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "500",
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--mono)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"letterSpacing": "0.02em"
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-wide", "title": "Wide page", "postTypes": ["page"] }
	]
}
